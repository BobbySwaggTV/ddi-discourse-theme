<div class="ddi-card">

  <div class="ddi-card-title">
    DOCUMENT INTELLIGENCE
  </div>

  <div class="ddi-intel-grid">

    <div>
      <span>Reading Time</span>
      <strong>--</strong>
    </div>

    <div>
      <span>Word Count</span>
      <strong>--</strong>
    </div>

    <div>
      <span>Category</span>
      <strong>{{this.category}}</strong>
    </div>

    <div>
      <span>Replies</span>
      <strong>{{this.replies}}</strong>
    </div>

    <div>
      <span>Views</span>
      <strong>{{this.views}}</strong>
    </div>

    <div>
      <span>Last Updated</span>
      <strong>--</strong>
    </div>

  </div>

</div>
