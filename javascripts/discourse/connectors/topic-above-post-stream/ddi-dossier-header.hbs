<div class="ddi-dossier-header">

  <div class="ddi-dossier-classification">
    PUBLIC RELEASE
  </div>

  <div class="ddi-dossier-grid">

    <div>
      <span>DOCUMENT ID</span>
      <strong class="ddi-document-id"></strong>
    </div>

    <div>
      <span>DOCUMENT TYPE</span>
      <strong>INTELLIGENCE BRIEF</strong>
    </div>

    <div>
      <span>AUTHOR</span>
      <strong class="ddi-author">{{author}}</strong>
    </div>

    <div>
      <span>STATUS</span>
      <strong>{{status}}</strong>
    </div>

  </div>

  <div class="ddi-dossier-issued ddi-issued-date"></div>

</div>